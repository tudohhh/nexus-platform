        "trigger": "trimite",
        "source": "DRAFT",
        "dest": "TRIMIS_FURNIZOR"
      },
      {
        "trigger": "confirma",
        "source": "TRIMIS_FURNIZOR",
        "dest": "CONFIRMAT_FURNIZOR"
      },
      {
        "trigger": "livreaza",
        "source": "CONFIRMAT_FURNIZOR",
        "dest": "IN_LIVRARE"
      },
      {
        "trigger": "finalizeaza",
        "source": "IN_LIVRARE",
        "dest": "LIVRAT"
      },
      {
        "trigger": "factureaza",
        "source": "LIVRAT",
        "dest": "FACTURAT"
      },
      {
        "trigger": "anuleaza",
        "source": "DRAFT",
        "dest": "ANULAT"
      },
      {
        "trigger": "anuleaza",
        "source": "TRIMIS_FURNIZOR",
        "dest": "ANULAT"
      },
      {
        "trigger": "anuleaza",
        "source": "CONFIRMAT_FURNIZOR",
        "dest": "ANULAT"
      }
    ],
