        "furnizor",
        "data_livrare_dorita",
        "linii"
      ],
      "properties": {
        "furnizor": {
          "type": "string",
          "enum": [
            "FARMACIA-HELP",
            "GEDEON-RICHTER",
            "ZENTIVA-RO"
          ]
        },
        "data_livrare_dorita": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "urgent": {
          "type": "boolean"
        },
        "note": {
          "type": "string",
          "maxLength": 500
        },
        "linii": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "produs",
              "cantitate",
              "pret_unitar",
              "um"
            ],
            "properties": {
              "produs": {
                "type": "string",
                "minLength": 2
              },
              "cantitate": {
                "type": "number",
                "minimum": 0.1
              },
              "pret_unitar": {
                "type": "number",
                "minimum": 0
              },
              "um": {
                "type": "string",
                "enum": [
                  "cutie",
                  "flacon",
                  "fiola",
                  "mg",
                  "ml",
                  "buc"
                ]
              },
              "cod_produs": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
