{
  "domain_id": "restaurant",
  "display_name": "Nexus Restaurant",
  "description": "Comenzi catering B2B cu livrare si reclamatie",
  "color_primary": "#f59e0b",
  "color_urgent": "#ef4444",
  "logo_letter": "R",
  "tenants": [
    "BIROU-ALPHA",
    "BIROU-BETA",
    "BIROU-GAMMA"
  ],
  "contract_id_prefix": "CMD-REST",
  "fsm": {
    "states": [
      "DRAFT",
      "CONFIRMAT",
      "IN_PREPARARE",
      "IN_LIVRARE",
      "LIVRAT",
      "RECLAMAT",
      "ANULAT"
    ],
    "transitions": [
      {
        "trigger": "confirma",
        "source": "DRAFT",
        "dest": "CONFIRMAT"
      },
      {
        "trigger": "incepe",
        "source": "CONFIRMAT",
        "dest": "IN_PREPARARE"
      },
      {
        "trigger": "livreaza",
        "source": "IN_PREPARARE",
        "dest": "IN_LIVRARE"
      },
      {
        "trigger": "finalizeaza",
        "source": "IN_LIVRARE",
        "dest": "LIVRAT"
      },
      {
        "trigger": "reclama",
        "source": "LIVRAT",
        "dest": "RECLAMAT"
      },
      {
        "trigger": "anuleaza",
        "source": "DRAFT",
        "dest": "ANULAT"
      },
      {
        "trigger": "anuleaza",
        "source": "CONFIRMAT",
        "dest": "ANULAT"
      }
    ],
    "urgent_field": "urgent",
    "urgent_state": "URGENT_LIVRARE"
  },
  "schemas": {
    "BIROU-ALPHA": {
      "type": "object",
      "required": [
        "client",
        "data_livrare",
        "slot",
        "adresa",
        "linii"
      ],
      "properties": {
        "client": {
          "type": "string",
          "minLength": 2
        },
        "data_livrare": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "slot": {
          "type": "string",
          "enum": [
            "10-12",
            "12-14",
            "14-16"
          ]
        },
        "adresa": {
          "type": "string",
          "minLength": 5
        },
        "urgent": {
          "type": "boolean"
        },
        "linii": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "produs",
              "cantitate",
              "pret_unitar"
            ],
            "properties": {
              "produs": {
                "type": "string"
              },
              "cantitate": {
                "type": "integer",
                "minimum": 1
              },
              "pret_unitar": {
                "type": "number",
                "minimum": 0
